{
  "version": 2,
  "name": "algo-dashboard",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ],
  "env": {
    "REACT_APP_BACKEND_URL": "https://your-backend.up.railway.app"
  }
}
